# Game files - DO NOT UPLOAD copyrighted game data, but allow BepInEx mod folder + required Doorstop files
GameFiles/*
!GameFiles/BepInEx/
!GameFiles/.doorstop_version
!GameFiles/doorstop_config.ini
!GameFiles/winhttp.dll
# Ignore logs and cache inside BepInEx
GameFiles/BepInEx/cache/
GameFiles/BepInEx/*.log
GameFiles/BepInEx/*/*.log
GameFiles/BepInEx/*/*/*.log
# Ignore non-essential files in GameFiles root
GameFiles/changelog.txt
GameFiles/CupheadPluginDebug.txt

