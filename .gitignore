# Game files – keep only the tiny Doorstop/BepInEx config and the built plugin/DLLs for ease of use
GameFiles/
!GameFiles/BepInEx/
!GameFiles/BepInEx/config/
!GameFiles/BepInEx/plugins/
!GameFiles/BepInEx/core/
!GameFiles/.doorstop_version
!GameFiles/doorstop_config.ini
!GameFiles/winhttp.dll
# Ignore non-essential files in the GameFiles root
GameFiles/changelog.txt
GameFiles/CupheadPluginDebug.txt

# Claude Code settings (local to user)
.claude/

# Build artifacts – we keep the built plugin DLLs under BepInEx, but ignore local build outputs
bin/
obj/
__pycache__/
*.pyc
*.pyo
*.pyd
*.log
*.cache

# IDE and editor files
.vscode/
.idea/
*.sln
*.csproj.user
*.suo
*.user
*.userosscache
*.sln.docstates

# Temporary files
*.tmp
*.temp
.DS_Store
Thumbs.db

# Python specific
.env
.venv
env/
venv/
ENV/
pip-log.txt
pip-delete-this-directory.txt
.tox/
.coverage
.cache
nosetests.xml
coverage.xml
*.cover
*.log
.hypothesis/
.pytest_cache/

# Cuphead plugin specific – we track the source and project file, but ignore the local lib copies (user should copy from their own install)
CupheadPlugin/lib/

# Logs (can be large)
cuphead_debug.log

# Documentation build artifacts
_build/

# Test recordings – we want to keep these for agent training logs
# (if you ever want to ignore them, uncomment the next line)
# test_recordings/
# *.csv

# Local test scripts – keep for development, but not required for end users
# (if you want to ignore them, uncomment the next line)
# PythonRL/test_*.py

# OS
Desktop.ini